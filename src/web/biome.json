{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "root": "../.."
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/test-results",
      "!**/playwright-report",
      "!**/*.svg"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noConsole": "off"
      },
      "style": {
        "useImportType": "error",
        "noNonNullAssertion": "off"
      },
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      }
    }
  },
  "javascript": {
    "globals": ["weavie", "MonacoEnvironment"]
  },
  "overrides": [
    {
      "includes": ["**/e2e/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noTemplateCurlyInString": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/chrome/ResizeFrame.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/editor/diff.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/src/chrome/Omnibar.tsx",
        "**/src/chrome/BranchTypeahead.tsx",
        "**/src/chrome/NewSessionPrompt.tsx",
        "**/src/chrome/DiffAgainstPrompt.tsx",
        "**/src/chrome/DeleteSessionDialog.tsx",
        "**/src/chrome/OpenPrPrompt.tsx",
        "**/src/chrome/SourceTokenPrompt.tsx",
        "**/src/chrome/RegisterAgentModal.tsx",
        "**/src/chrome/UrlPrompt.tsx",
        "**/src/chrome/SearchPanel.tsx",
        "**/src/files/FileBrowser.tsx",
        "**/src/editor/ConfirmDialog.tsx",
        "**/src/editor/preview/EmbedLightbox.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off",
            "useFocusableInteractive": "off"
          }
        }
      }
    }
  ]
}
