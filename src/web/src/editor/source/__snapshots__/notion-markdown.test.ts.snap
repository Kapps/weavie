exports[`golden corpus > renders kitchen-sink 1`] = `"<h1 id="wv-h-heading-one" class="wv-editable wv-color-red" data-wv-line="0">Heading one</h1><h2 id="wv-h-heading-two" class="wv-editable wv-bg-orange" data-wv-line="1">Heading two</h2><h3 id="wv-h-heading-three" class="wv-editable" data-wv-line="2">Heading three</h3><details class="wv-toggle-heading"><summary><h2 id="wv-h-toggle-heading" class="wv-editable wv-color-purple" data-wv-line="3">Toggle heading</h2></summary><div class="wv-children"><p class="wv-editable" data-wv-line="4">Hidden child paragraph.</p><ul><li class="wv-editable" data-wv-line="5">Hidden bullet</li></ul></div></details><p class="wv-editable" data-wv-line="6">Plain paragraph with <strong>bold</strong>, <em>italic</em>, <s>strike</s>, <code>code</code>, <a href="https://example.com">link</a>, <code class="wv-math">E=mc^2</code>, <span class="wv-underline">underlined</span>, <span class="wv-color-green">green text</span>, <span class="wv-bg-yellow">highlighted</span>, and a line<br>break.</p><div class="wv-children"><p class="wv-editable" data-wv-line="7">A tab-nested child paragraph under the paragraph above.</p></div><ul><li class="wv-editable wv-color-blue" data-wv-line="8">Bullet one<div class="wv-children"><ul><li class="wv-editable" data-wv-line="9">Nested bullet<div class="wv-children"><ol><li class="wv-editable" data-wv-line="10">Deep numbered item</li></ol></div></li></ul><p class="wv-editable" data-wv-line="11">Paragraph child of bullet one.</p></div></li><li class="wv-editable" data-wv-line="12">Bullet two</li></ul><ol><li class="wv-editable" data-wv-line="13">Numbered one<div class="wv-children"><ol><li class="wv-editable" data-wv-line="14">Numbered nested</li></ol><ul><li class="wv-editable" data-wv-line="15">Bullet under numbered</li></ul></div></li><li class="wv-editable" data-wv-line="16">Numbered two</li></ol><ul class="wv-todos"><li class="wv-todo wv-editable wv-color-gray" data-wv-line="17"><input type="checkbox" disabled><span class="wv-todo-text">Unchecked task</span><div class="wv-children"><ul class="wv-todos"><li class="wv-todo wv-editable" data-wv-line="18"><input type="checkbox" checked disabled><span class="wv-todo-text">Nested checked task</span></li></ul><p class="wv-editable" data-wv-line="19">Task child paragraph.</p></div></li><li class="wv-todo wv-editable" data-wv-line="20"><input type="checkbox" checked disabled><span class="wv-todo-text">Checked task</span></li></ul><blockquote class="wv-editable wv-bg-brown" data-wv-line="21">Quoted rich text<div class="wv-children"><p class="wv-editable" data-wv-line="22">Quote child paragraph.</p></div></blockquote><blockquote class="wv-editable" data-wv-line="23">Line 1<br>Line 2<br>Line 3</blockquote><details class="wv-color-pink"><summary>Toggle title</summary><div class="wv-children"><p class="wv-editable" data-wv-line="26">Toggle child one.</p><aside class="wv-callout"><span class="wv-icon">⚠️</span><div class="wv-callout-body"><p class="wv-editable" data-wv-line="28">Nested callout inside a toggle.</p></div></aside></div></details><aside class="wv-callout wv-bg-gray"><span class="wv-icon">💡</span><div class="wv-callout-body"><p class="wv-editable" data-wv-line="32">Callout body with <strong>marks</strong>.</p><ul><li class="wv-editable" data-wv-line="33">A list inside the callout</li></ul></div></aside><pre class="mermaid-pending">graph TD; A--&gt;B;</pre><div class="wv-equation">\\int_0^1 x^2 dx</div><table><tr class="wv-bg-gray"><th class="wv-bg-blue">Name</th><th>Value</th></tr><tr><td class="wv-color-red">Alpha</td><td>1</td></tr></table><table><tr><th>GFM</th><th>Table</th></tr><tr><td>pipe</td><td>cells</td></tr></table><hr><div class="wv-columns"><div class="wv-column"><p class="wv-editable" data-wv-line="62">Left column text.</p></div><div class="wv-column"><p class="wv-editable" data-wv-line="65">Right column text.</p></div></div><p class="wv-editable wv-bg-blue" data-wv-line="68"><img src="https://example.com/img.png" alt="A caption"></p><a class="wv-card" href="https://example.com/a.mp3">Audio caption</a><a class="wv-card" href="https://example.com/v.mp4">Video caption</a><a class="wv-card" href="https://example.com/f.zip">File caption</a><a class="wv-card" href="https://example.com/d.pdf">PDF caption</a><a class="wv-card" href="https://www.notion.so/Sub-page-1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d">Sub page</a><a class="wv-card" href="https://www.notion.so/1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6e">📚 Tasks DB</a><nav class="wv-toc wv-color-gray"><ul><li class="wv-toc-l1"><a href="#wv-h-heading-one">Heading one</a></li><li class="wv-toc-l2"><a href="#wv-h-heading-two">Heading two</a></li><li class="wv-toc-l3"><a href="#wv-h-heading-three">Heading three</a></li><li class="wv-toc-l2"><a href="#wv-h-toggle-heading">Toggle heading</a></li></ul></nav><p class="wv-editable" data-wv-line="77">Synced content paragraph.</p><p class="wv-editable" data-wv-line="80">Referenced synced content.</p><a class="wv-card" href="https://www.notion.so/1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c70">link preview</a><p class="wv-editable" data-wv-line="83">Mentions: <a href="{{user://abc}}">Ada Lovelace</a> and <a href="https://www.notion.so/Other-1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c71">Other page</a> and 2026-07-01 → 2026-07-04 and 2026-07-02 09:00.</p><p class="wv-editable" data-wv-line="84">Custom emoji :party_blob: and a citation.[^https://example.com/source]</p><p class="wv-editable" data-wv-line="85">Escapes: *not bold*, &lt;not a tag&gt;, {not attrs}, $not math$, a|pipe, up^caret, ~tilde~, \`tick\`, [brackets].</p><p class="wv-editable" data-wv-line="86">A literal trailing brace block {note} stays text.</p>"`;

exports[`golden corpus > renders real-page 1`] = `"<p class="wv-editable" data-wv-line="1">This is a test page for testing.</p><aside class="wv-callout wv-bg-green"><span class="wv-icon">💡</span><div class="wv-callout-body"><p class="wv-editable" data-wv-line="3">Test Callout</p></div></aside><h3 id="wv-h-image" class="wv-editable" data-wv-line="5">Image</h3><p class="wv-editable" data-wv-line="6">Lets add an image.</p><p class="wv-editable" data-wv-line="7"><img src="https://example.com/image.png?a=1&amp;b=2" alt=""></p><p class="wv-editable" data-wv-line="9">Coo.</p><p class="wv-editable" data-wv-line="10">And<a href="http://google.ca"> https://google.ca</a></p><details class="wv-toggle-heading"><summary><h2 id="wv-h-testing" class="wv-editable" data-wv-line="11">Testing</h2></summary><div class="wv-children"><aside class="wv-callout wv-bg-green"><span class="wv-icon">💡</span><div class="wv-callout-body"><p class="wv-editable" data-wv-line="13">arr</p></div></aside></div></details>"`;
